@page "/emulated"
@using MuddyStargateWasm.Services

@inject StargateConnection connection

<PageTitle>Emulated StarGate</PageTitle>

<MudTextField @bind-Value="TargetAddress" Label="Outlined" Variant="Variant.Outlined" Clearable></MudTextField>
<MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="Connect" Disabled="@connection.IsWSConnected">Connect</MudButton>
<MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="Dial" Disabled="@(!connection.IsWSConnected)">Dial</MudButton>


<MudSpacer/>
<MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="Kill" Disabled="@(!connection.IsWormholeOpen)">Close Wormhole</MudButton>

@code {
    public string TargetAddress { get; set; } = "DJTESGP@";

    private async void Connect(MouseEventArgs args)
    {
        connection.OnChange += () => InvokeAsync(StateHasChanged);
        
        await connection.FreshClient();
        await connection.RequestAddress();
        await InvokeAsync(StateHasChanged);
        
    }

    private async void Dial()
    {
        await connection.DialRequest(TargetAddress);
    }

    private async void Kill()
    {
        await connection.CloseWormhole();
        await InvokeAsync(StateHasChanged);
    }
}
