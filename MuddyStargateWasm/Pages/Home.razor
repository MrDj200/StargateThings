@page "/"
@using MuddyStargateWasm.Models
@using System.Text
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject AppBarState AppBarState


<PageTitle>Home</PageTitle>

<MudText Align="Align.Center" Typo="Typo.h4" GutterBottom="true">Found @ActiveGates.Count() active gates with @TotalUsers() active user@(TotalUsers() != 1 ? "s" : "")! @OpenGates().Count() open gates</MudText>

<MudGrid Spacing="3">
    @* <MudVirtualize Items="@OpenGates" ItemSize="250" OverscanCount="20" Context="gate" @ref="_virtualizeRef"> *@
        
    @foreach (var gate in ActiveGates.OrderByDescending(x => x.active_users))
    {
        gate.UseCustomFont = false;
        #if DEBUG
        //gate.gate_status = CoinFlip()? "IDLE" : "OPEN"; // IDLE, OPEN
        #endif
        <MudItem xs="6" sm="4" md="3" lg="2">
            <MudCard Outlined="true"
                     Square="false"
                     Style="overflow: hidden"
                     Class=@GetGateCardClass(gate)>

                <MudCardHeader>
                    <MudTooltip Text="@gate.session_name" Placement="Placement.Bottom">
                        <MudText Class="clamp-1" Typo="Typo.h6" Color="@(gate.iris_state ? Color.Error : Color.Default)">@gate.session_name</MudText>
                    </MudTooltip>
                    <MudSpacer />
                    <MudTooltip Text=@(gate.is_headless? "Headless" : "User hosted") >
                        <MudIcon Icon=@(gate.is_headless? @Icons.Material.Filled.Storage : @Icons.Material.Filled.Person)/>
                    </MudTooltip>                    
                </MudCardHeader>
                <MudCardContent>
                    
                    <MudLink OnClick="@(_ => CopyTextToClipboard(gate.FullCode))" EndIcon="@Icons.Material.Filled.ContentCopy" Color="Color.Inherit">
                        <MudText Inline="true">Address: </MudText><MudText Class="@gate.AddressFontClass" Inline="true" Color="Color.Secondary">@gate.gate_address</MudText><MudText Class="@gate.AddressFontClass" Inline="true" Color="Color.Primary">@gate.CleanCode</MudText>
                    </MudLink>
                    
                    @* <MudIcon Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small" /> *@
                    <MudSpacer />
                    <MudText Inline="true">Users: </MudText>
                    <MudText Inline="true" Color=@(gate.active_users < 1 ? Color.Inherit : Color.Success)>@gate.active_users</MudText><MudText Inline="true">/@gate.max_users</MudText>
                </MudCardContent>
                <MudCardActions>
                    @* @if (gate.gate_status != "IDLE")
                    {
                        <MudChip  T="string" Color="Color.Info" Variant="Variant.Text">@gate.gate_status</MudChip>
                    } *@
                </MudCardActions>
            </MudCard>
        </MudItem>
    }

    @* </MudVirtualize> *@
</MudGrid>


@code{

    public string status { get; set; } = "N/A";
    private IEnumerable<StargateInfo> ActiveGates { get; set; } = new StargateInfo[0];
    //private MudVirtualize<StargateModel>? _virtualizeRef;

    async void UpdateGatesAsync()
    {
        var http = new HttpClient();
        var data = await http.GetFromJsonAsync<List<StargateInfo>>("https://cors-proxy.djs-cors-proxy.workers.dev/");

        if (data != null)
        {
            ActiveGates = data;
            //await _virtualizeRef.RefreshDataAsync();
        }

        StateHasChanged();
    }

    protected override void OnInitialized()
    {
        AppBarState.SetRefresh(UpdateGatesAsync);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            UpdateGatesAsync();
        }
    }

    private int TotalUsers() => ActiveGates.Sum(x => x.active_users);

    private IEnumerable<StargateInfo> OpenGates() => ActiveGates.Where(x => x.Status == GateStatus.OPEN);

    private bool CoinFlip() => new Random().Next(2) == 1;

    private string GetGateCardClass(StargateInfo gate)
    {
        var sb = new StringBuilder();
        sb.Append("hover-card ");
        if (gate.Status == GateStatus.OPEN)
        {
            sb.Append("active-gate ");
        }
        return sb.ToString();
    }

    private async Task CopyTextToClipboard(string text)
    {
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
        Snackbar.Add("Gate code copied to clipboard!", Severity.Success);
    }
}